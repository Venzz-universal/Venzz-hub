-- Venzz Hub Full Clean (No Icons)
local WindUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/Footagesus/WindUI/main/dist/main.lua" .. "?v=" .. tick()))()

local Window = WindUI:CreateWindow({
    Title = "Venzz Hub",
    Folder = "VenzzHub",
    HideSearchBar = false,
    OpenButton = { Title = "Venzz Hub", Enabled = true, Draggable = true, Scale = 0.5 },
})

-- TAB: HOME
local HomeTab = Window:Tab({ Title = "Home" })
HomeTab:Button({
    Title = "Copy Discord Link",
    Callback = function()
        setclipboard("https://discord.gg/Vn2Zg7ZvV")
        WindUI:Notify({Title = "Venzz Hub", Content = "Discord link copied!"})
    end,
})

-- TAB: FEATURES
local FeatTab = Window:Tab({ Title = "Features" })
FeatTab:Toggle({
    Title = "Enable Custom Script",
    Callback = function(state)
        if state then
            _G.ScriptLoaded = loadstring(game:HttpGet("https://pastefy.app/qEKYpfj0/raw"))()
            WindUI:Notify({Title = "Venzz Hub", Content = "Script Aktif!"})
        else
            WindUI:Notify({Title = "Venzz Hub", Content = "Script dinonaktifkan"})
        end
    end,
})

-- TAB: SCRIPT HUB
local ScriptTab = Window:Tab({ Title = "Script Hub" })

ScriptTab:Button({
    Title = "time bomb script clasic",
    Color = Color3.fromHex("#30a2ff"),
    Callback = function()
        local lp = game.Players.LocalPlayer
        local target = nil
        local dist = math.huge
        for _, v in pairs(game.Players:GetPlayers()) do
            if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local mag = (v.Character.HumanoidRootPart.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                if mag < dist then target = v.Character.HumanoidRootPart; dist = mag end
            end
        end
        if target then lp.Character.HumanoidRootPart.CFrame = target.CFrame * CFrame.new(0, 0, 3) end
    end,
})

ScriptTab:Button({
    Title = "dua script",
    Color = Color3.fromHex("#a2ff30"),
    Callback = function()
        local CurrentID = game.PlaceId
        if CurrentID == 142823291 then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/script-9209/roblox/refs/heads/main/mm2-keyless-auto"))()
        elseif CurrentID == 93978595733734 then
            loadstring(game:HttpGet("https://raw.githubusercontent.com/numerouno2/eugunewupremium/refs/heads/main/main.lua"))()
        else
            WindUI:Notify({Title = "Venzz Hub", Content = "No script for ID: " .. CurrentID})
        end
    end,
})

-- TAB: SETTINGS
local SettingsTab = Window:Tab({ Title = "Settings" })
SettingsTab:Button({
    Title = "Destroy UI",
    Color = Color3.fromHex("#ff4830"),
    Callback = function() Window:Destroy() end,
})
